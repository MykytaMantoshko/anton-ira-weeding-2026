---
import { Image } from "astro:assets";
import finalImg from "../assets/final-img.jpg";
import clothes1 from "../assets/clothes-1.jpg";
import clothes2 from "../assets/clothes-2.jpg";
import clothes3 from "../assets/clothes-3.jpg";
import clothes4 from "../assets/clothes-4.jpg";
import clothes5 from "../assets/clothes-5.jpg";
import clothes6 from "../assets/clothes-6.jpg";
import clothes7 from "../assets/clothes-7.jpg";
import antonIra1 from "../assets/anton-ira-1.jpg";
import antonIra2 from "../assets/anton-ira-2.jpg";
import img1 from "../assets/image-1.jpg";
import img2 from "../assets/image-2.jpg";
import img3 from "../assets/image-3.jpg";
import img4 from "../assets/image-4.jpg";
import img5 from "../assets/image-5.jpg";
import img6 from "../assets/image-6.jpg";
import sky1 from "../assets/sky-1.jpg";
import sky2 from "../assets/sky-2.jpg";
import sky3 from "../assets/sky-3.jpg";
import skyLogo from "../assets/sky-logo.png";
import loaderLside from "../assets/stamp-lside.png";
import loaderRside from "../assets/stamp-rside.png";
import stamp from "../assets/stamp.png";
import "../styles/global.css";
import Section from "../components/Section.astro";

const galleryImages = [
  { src: img1, alt: "Ірина та Антон" },
  { src: img2, alt: "Ірина та Антон" },
  { src: img3, alt: "Ірина та Антон" },
  { src: img4, alt: "Ірина та Антон" },
  { src: img5, alt: "Ірина та Антон" },
  { src: img6, alt: "Ірина та Антон" },
];

const clothesSlides = [
  { src: clothes1, alt: "Дрес-код, приклад 1" },
  { src: clothes2, alt: "Дрес-код, приклад 2" },
  { src: clothes3, alt: "Дрес-код, приклад 3" },
  { src: clothes4, alt: "Дрес-код, приклад 4" },
  { src: clothes5, alt: "Дрес-код, приклад 5" },
  { src: clothes6, alt: "Дрес-код, приклад 6" },
  { src: clothes7, alt: "Дрес-код, приклад 7" },
];
---

<html lang="ua" class="w-full max-w-full overflow-x-hidden">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="viewport" content="width=device-width" />
    <title>Запрошуємо вас на весілля 2026 — Ірина та Антон</title>
    <link
      rel="preload"
      href="/font/Montserrat-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/font/CormorantGaramond-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/font/Kapakana-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body class="w-full max-w-full overflow-x-hidden">
    <main class="w-full relative">
      <section id="preloader" class="preloader">
        <div class="preloader-inner">
          <div class="preloader-left">
            <Image
              src={loaderLside}
              alt=""
              class="w-full h-full object-cover object-center"
              loading="eager"
              fetchpriority="high"
            />
          </div>
          <div class="preloader-right">
            <Image
              src={stamp}
              alt=""
              class="absolute top-1/2 left-[-37.5%] lg:left-[-12.5%] -translate-y-1/2 object-contain z-4 w-[75%] lg:w-[25%] rotate-20"
              loading="eager"
              fetchpriority="high"
            />
            <Image
              src={loaderLside}
              alt=""
              class="absolute top-0 left-0 w-full h-full object-cover object-left"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        </div>
      </section>
      <Section
        class="mt-12.5 mb-30"
        innerClass="flex flex-col gap-6 items-center text-center"
      >
        <p class="date-hero font-h1 text-[1.5rem]!">21 | 06 | 2026</p>
        <h1 class="font-kapakana">Wedding day</h1>
        <div class="flex flex-col text-center items-center">
          <p class="font-h1 uppercase z-2 relative">Ірина</p>
          <div
            class="gallery-scroll w-full max-w-80 mx-auto relative z-1 -my-4"
          >
            <div class="gallery-track">
              {
                [...galleryImages, ...galleryImages].map(({ src, alt }) => (
                  <div class="gallery-item rounded-lg overflow-hidden">
                    <Image src={src} alt={alt} class="gallery-img rounded-lg" />
                  </div>
                ))
              }
            </div>
          </div>
          <p class="font-h1 uppercase z-2 relative">Антон</p>
        </div>
      </Section>
      <Section
        class="mb-22.5"
        innerClass="flex flex-col gap-6 items-center text-center"
      >
        <h2>Дорогі друзі та рідні!</h2>
        <p>
          З радістю та любовʼю запрошуємо вас розділити з нами особливий день <nobr
            >- <i class="font-medium border-b">день нашого весілля</i></nobr
          >
        </p>
      </Section>
      <Section
        class="mb-22.5"
        innerClass="flex flex-col gap-5 items-center text-center"
      >
        <p class="text-green font-semibold -mb-2">Червень</p>
        <div
          class="calendar flex flex-col gap-6 w-full max-w-71 mx-auto text-green"
        >
          <div class="grid grid-cols-7 gap-6 font-semibold">
            <div>Пн</div>
            <div>Вт</div>
            <div>Ср</div>
            <div>Чт</div>
            <div>Пт</div>
            <div>Сб</div>
            <div>Нд</div>
          </div>
          <div class="grid grid-cols-7 gap-6">
            <div>1</div>
            <div>2</div>
            <div>3</div>
            <div>4</div>
            <div>5</div>
            <div>6</div>
            <div>7</div>
          </div>
          <div class="grid grid-cols-7 gap-6">
            <div>8</div>
            <div>9</div>
            <div>10</div>
            <div>11</div>
            <div>12</div>
            <div>13</div>
            <div>14</div>
          </div>
          <div class="grid grid-cols-7 gap-6">
            <div>15</div>
            <div>16</div>
            <div>17</div>
            <div>11</div>
            <div>19</div>
            <div>20</div>
            <div class="relative font-semibold text-white">
              <img
                src="/icon/heart.svg"
                alt="calendar-icon"
                class="flex absolute top-[calc(50%+2px)] left-1/2 -translate-x-1/2 -translate-y-1/2 min-w-8.25 h-7.5"
              />
              <span class="relative z-2">21</span>
            </div>
          </div>
          <div class="grid grid-cols-7 gap-6">
            <div>22</div>
            <div>23</div>
            <div>24</div>
            <div>25</div>
            <div>26</div>
            <div>27</div>
            <div>28</div>
          </div>
          <div class="grid grid-cols-7 gap-6">
            <div>29</div>
            <div>30</div>
          </div>
        </div>
        <i class="text-green text-[0.875rem]">День коли ми станемо родиною!</i>
      </Section>
      <Section class="mb-27.5" innerClass="pt-9 pb-40 relative">
        <div
          class="flex flex-col items-center justify-center px-4 h-62.5 bg-white rounded-lg text-center relative z-2 gap-2"
        >
          <p>
            Це буде день, який ми запамʼятаємо назавжди, і нам буде надзвичайно
            приємно бачити вас поруч.
          </p>
          <p>
            Ми щиро віримо і сподіваємось, що цей день стане красивим початком
            нашого спільного життя.
          </p>
          <p class="font-kapakana text-[1.625rem]">Irina and Anton</p>
        </div>
        <img
          src="/icon/convert.svg"
          alt="calendar-icon"
          class="flex absolute top-0 left-6.5 min-w-103 w-103"
        />
        <img
          src="/icon/convert-right.svg"
          alt="calendar-icon"
          class="flex absolute top-[9.8rem] left-75 min-w-43 z-2"
        />
        <img
          src="/icon/convert-bottom.svg"
          alt="calendar-icon"
          class="flex absolute bottom-0 left-16 min-w-102.5 z-3"
        />
      </Section>
      <Section
        class="mb-33"
        innerClass="flex flex-col gap-5 items-center text-center"
      >
        <h2>Локація</h2>
        <Image src={skyLogo} alt="Sky Logo" class="w-full max-w-47" />
        <div class="grid grid-cols-3 gap-1.25 mb-14">
          <Image
            src={sky1}
            alt="Sky"
            class="w-full aspect-[1/1.42] rounded-lg object-cover"
          />
          <Image
            src={sky2}
            alt="Sky"
            class="w-full aspect-[1/1.42] rounded-lg object-cover"
          />
          <Image
            src={sky3}
            alt="Sky"
            class="w-full aspect-[1/1.42] rounded-lg object-cover"
          />
        </div>
        <p class="text-[1.25rem]">
          місто Київ. Туманяна 15А<br /> секція "В". 27 поверх
        </p>

        <a
          href="https://maps.app.goo.gl/wwwpJzmwFYyZeu226"
          target="_blank"
          class="text-green transition-all py-2.5 px-4 border border-green rounded-lg leading-none uppercase font-semibold hover:bg-green hover:text-white"
          >Побачити на карті</a
        >
      </Section>
      <Section
        class="bg-green text-white py-12.5 mb-27.5 bordered-dotted"
        innerClass="flex flex-col items-center text-center"
      >
        <h2 class="mb-12.5">ПРОГРАМА ДНЯ</h2>
        <div
          class="flex flex-col items-center w-full max-w-48 mx-auto gap-3.75 mb-11"
        >
          <img src="/icon/zbor.svg" alt="Збір гостей" class="w-22.5 h-4.6875" />
          <p
            class="font-h2 text-[3.125rem]! number-fix time-with-lines mb-1.25"
          >
            00:00
          </p>
          <p class="text-[1.25rem]">Збір гостей</p>
        </div>
        <div
          class="flex flex-col items-center w-full max-w-48 mx-auto gap-3.75 mb-9"
        >
          <img
            src="/icon/ceremoniya.svg"
            alt="Церемонія"
            class="w-17.5 h-17.5"
          />
          <p
            class="font-h2 text-[3.125rem]! number-fix time-with-lines mb-1.25"
          >
            00:00
          </p>
          <p class="text-[1.25rem]">Церемонія</p>
        </div>
        <div
          class="flex flex-col items-center w-full max-w-48 mx-auto gap-3.75 mb-9"
        >
          <img
            src="/icon/furshet.svg"
            alt="Святковий фуршет"
            class="w-22.5 h-19.25"
          />
          <p
            class="font-h2 text-[3.125rem]! number-fix time-with-lines mb-1.25"
          >
            00:00
          </p>
          <p class="text-[1.25rem]">Святковий фуршет</p>
        </div>
        <div
          class="flex flex-col items-center w-full max-w-48 mx-auto gap-3.75"
        >
          <img
            src="/icon/tort.svg"
            alt="Весільний торт"
            class="w-22.5 h-17.5"
          />
          <p
            class="font-h2 text-[3.125rem]! number-fix time-with-lines mb-1.25"
          >
            00:00
          </p>
          <p class="text-[1.25rem]">Весільний торт</p>
        </div>
      </Section>
      <Section
        class="mb-20"
        innerClass="flex flex-col gap-5 items-center text-center"
      >
        <h2>ДРЕС-КОД</h2>
        <p>
          Будемо вдячні, якщо ви підтримаєте настрій нашого свята у своїх
          образах. Ми не обмежуємо вас у виборі кольору, проте просимо надати
          перевагу будь-яким пастельним відтінкам.
        </p>
        <div class="grid grid-cols-7 gap-0.5 w-full">
          <div class="w-full h-21.25 rounded-lg bg-[#848983]"></div>
          <div class="w-full h-21.25 rounded-lg bg-[#B9C0B8]"></div>
          <div class="w-full h-21.25 rounded-lg bg-[#D9E2E6]"></div>
          <div class="w-full h-21.25 rounded-lg bg-[#F5E8CE]"></div>
          <div class="w-full h-21.25 rounded-lg bg-[#F2D3D3]"></div>
          <div class="w-full h-21.25 rounded-lg bg-[#DFCFB7]"></div>
          <div class="w-full h-21.25 rounded-lg bg-[#A29480]"></div>
        </div>
      </Section>
      <Section
        class="mb-26.25"
        innerClass="flex flex-col gap-6 items-center text-center"
      >
        <p class="max-w-72.5">
          Для вашої зручності, ми зібрали декілька прикладів:
        </p>
        <div class="clothes-slider w-full max-w-46.5 -mb-5">
          <div class="clothes-slider-track flex flex-row">
            {
              [...clothesSlides, ...clothesSlides].map(({ src, alt }) => (
                <div class="clothes-slider-slide shrink-0 w-full">
                  <Image
                    src={src}
                    alt={alt}
                    class="w-full aspect-[1/1.15] rounded-lg object-cover"
                  />
                </div>
              ))
            }
          </div>
        </div>
        <div
          class="flex flex-row gap-1.25 w-full max-w-25 items-center justify-between"
        >
          <button
            type="button"
            class="clothes-slider-prev flex items-center justify-center w-12 h-5 cursor-pointer transition-all hover:opacity-50"
            aria-label="Попередній"
          >
            <img src="/icon/arrow-left.svg" alt="" class="w-4.5" />
          </button>
          <button
            type="button"
            class="clothes-slider-next flex items-center justify-center w-12 h-5 cursor-pointer transition-all hover:opacity-50"
            aria-label="Наступний"
          >
            <img src="/icon/arrow-right.svg" alt="" class="w-4.5" />
          </button>
        </div>
        <script is:inline src="/scripts/clothes-slider.js"></script>
      </Section>
      <Section
        class="mb-26"
        innerClass="flex flex-col gap-6 items-center text-center"
      >
        <h2>ПОБАЖАННЯ</h2>
        <p>
          Ми мріємо про затишну власну оселю та незабутню спільну подорож, тому
          будемо безмежно вдячні, якщо ваші привітання будуть у вигляді
          грошового внеску в нашу мрію.
        </p>
        <div class="grid grid-cols-2 gap-1.25 my-6">
          <Image
            src={antonIra1}
            alt="Антон та Ірина"
            class="w-full aspect-[1/1.15] rounded-lg object-cover"
          />
          <Image
            src={antonIra2}
            alt="Антон та Ірина"
            class="w-full aspect-[1/1.15] rounded-lg object-cover"
          />
        </div>
        <p>
          А щоб наше свято мало довгий посмак — замість квітів, які швидко
          в’януть, просимо дарувати пляшку вашого улюбленого напою. Ми з радістю
          відкоркуємо її за ваше здоров'я на наших майбутніх сімейних вечорах!
        </p>
      </Section>
      <Section
        id="rsvp-form-section"
        class="mb-27.5"
        innerClass="flex flex-col gap-6 items-center text-center"
      >
        <div
          id="rsvp-form-preloader"
          class="rsvp-form-preloader hidden w-full flex-col gap-4 items-center justify-center py-12"
        >
          <div
            class="rsvp-form-preloader-spinner w-10 h-10 border-2 border-green border-t-transparent rounded-full animate-spin"
            aria-hidden="true"
          >
          </div>
          <p class="text-ink">Перевіряємо анкету…</p>
        </div>
        <div
          id="rsvp-form-content"
          class="rsvp-form-content w-full flex flex-col gap-6 items-center"
        >
          <h2 class="border-b">Анкета</h2>
          <p class="mb-6">
            Будь ласка, підтвердіть свою присутність на нашому весіллі
            заповнивши коротку анкету<br />
            <strong>до 00 травня</strong>
          </p>
          <form id="rsvp-form" class="rsvp-form w-full flex flex-col gap-6">
            <div class="flex flex-col gap-1.25 mb-6">
              <input
                type="text"
                id="rsvp-firstName"
                name="firstName"
                placeholder="Ім'я"
                class="rsvp-input w-full h-10 bg-white text-ink placeholder:text-[#6b6560] focus:outline-none focus:border-green transition-colors rounded-lg text-center border border-transparent"
                autocomplete="given-name"
              />
              <span
                id="rsvp-error-firstName"
                class="rsvp-error text-red text-sm text-center hidden mb-2"
                aria-live="polite"></span>
              <input
                type="text"
                id="rsvp-lastName"
                name="lastName"
                placeholder="Прізвище"
                class="rsvp-input w-full h-10 bg-white text-ink placeholder:text-[#6b6560] focus:outline-none focus:border-green transition-colors rounded-lg text-center border border-transparent"
                autocomplete="family-name"
              />
              <span
                id="rsvp-error-lastName"
                class="rsvp-error text-red text-sm text-center hidden"
                aria-live="polite"></span>
            </div>

            <fieldset class="flex flex-col">
              <legend class="font-semibold mb-6">
                Чи плануєте ви бути на нашому весіллі?
              </legend>
              <div class="flex flex-row items-center justify-center gap-12.5">
                <label
                  class="rsvp-radio-label flex items-center gap-2 cursor-pointer"
                >
                  <input
                    type="radio"
                    name="attendance"
                    value="yes"
                    class="rsvp-radio"
                  />
                  <span>Так</span>
                </label>
                <label
                  class="rsvp-radio-label flex items-center gap-2 cursor-pointer"
                >
                  <input
                    type="radio"
                    name="attendance"
                    value="no"
                    class="rsvp-radio"
                  />
                  <span>Ні</span>
                </label>
              </div>
            </fieldset>
            <span
              id="rsvp-error-attendance"
              class="rsvp-error text-red text-sm -mt-4 hidden"
              aria-live="polite"></span>

            <fieldset class="flex flex-col my-6">
              <legend class="font-semibold mb-6">
                Ваші побажання по алкоголю:
              </legend>
              <div class="grid grid-cols-2 gap-5">
                <label
                  class="rsvp-checkbox-label flex items-center gap-2 cursor-pointer"
                >
                  <input
                    type="checkbox"
                    name="alcohol"
                    value="whiskey"
                    class="rsvp-checkbox"
                  />
                  <span>Віскі</span>
                </label>
                <label
                  class="rsvp-checkbox-label flex items-center gap-2 cursor-pointer"
                >
                  <input
                    type="checkbox"
                    name="alcohol"
                    value="white-wine"
                    class="rsvp-checkbox"
                  />
                  <span>Вино біле</span>
                </label>
                <label
                  class="rsvp-checkbox-label flex items-center gap-2 cursor-pointer"
                >
                  <input
                    type="checkbox"
                    name="alcohol"
                    value="red-wine"
                    class="rsvp-checkbox"
                  />
                  <span>Вино червоне</span>
                </label>
                <label
                  class="rsvp-checkbox-label flex items-center gap-2 cursor-pointer"
                >
                  <input
                    type="checkbox"
                    name="alcohol"
                    value="champagne"
                    class="rsvp-checkbox"
                  />
                  <span>Шампанське</span>
                </label>
                <label
                  class="rsvp-checkbox-label flex items-center gap-2 cursor-pointer"
                >
                  <input
                    type="checkbox"
                    name="alcohol"
                    value="vodka"
                    class="rsvp-checkbox"
                  />
                  <span>Горілка</span>
                </label>
                <label
                  class="rsvp-checkbox-label flex items-center gap-2 cursor-pointer"
                >
                  <input
                    type="checkbox"
                    name="alcohol"
                    value="cognac"
                    class="rsvp-checkbox"
                  />
                  <span>Коньяк</span>
                </label>
                <label
                  class="rsvp-checkbox-label flex items-center gap-2 cursor-pointer"
                >
                  <input
                    type="checkbox"
                    name="alcohol"
                    value="rum"
                    class="rsvp-checkbox"
                  />
                  <span>Ром</span>
                </label>
              </div>
            </fieldset>
            <textarea
              name="notes"
              placeholder="Тут ви можете зазначити будь-яку важливу для вас інформацію..."
              rows="4"
              class="rsvp-textarea w-full px-5 py-3 mb-6 rounded-lg bg-white text-ink placeholder:text-[#6b6560] focus:outline-none focus:border-green transition-colors resize-y min-h-24"
            ></textarea>

            <span
              id="rsvp-error-submit"
              class="rsvp-error text-red text-sm text-center hidden mb-2"
              aria-live="polite"></span>
            <button
              type="submit"
              id="rsvp-submit"
              class="w-auto self-center cursor-pointer py-2.5 px-4 border border-green rounded-lg text-green font-semibold uppercase leading-none transition-all hover:bg-green hover:text-white disabled:opacity-50 disabled:cursor-not-allowed"
            >
              ПІДТВЕРДИТИ
            </button>
          </form>
        </div>
      </Section>
      <Section
        id="rsvp-thank-you-yes"
        class="hidden mb-27.5"
        innerClass="flex flex-col gap-6 items-center text-center"
      >
        <h2>Дякую!</h2>
        <p class="max-w-75">
          <span id="rsvp-thank-you-name" class="border-b">Ім’я</span> що будеш з нами
          в цей важливий день!
        </p>
        <button
          type="button"
          id="rsvp-edit-yes"
          class="w-auto self-center cursor-pointer py-2.5 px-4 border border-green rounded-lg text-green font-semibold uppercase leading-none transition-all hover:bg-green hover:text-white"
        >
          Змінити анкету
        </button>
      </Section>
      <Section
        id="rsvp-thank-you-no"
        class="hidden mb-27.5"
        innerClass="flex flex-col gap-6 items-center text-center"
      >
        <h2>Дякую що<br /> повідомили!!</h2>
        <p class="max-w-75">Нам дуже шкода, що вас не буде на нашому святі</p>
        <button
          type="button"
          id="rsvp-edit-no"
          class="w-auto self-center cursor-pointer py-2.5 px-4 border border-green rounded-lg text-green font-semibold uppercase leading-none transition-all hover:bg-green hover:text-white"
        >
          Змінити анкету
        </button>
      </Section>
      <Section
        class="pb-12"
        innerClass="flex flex-col gap-6 items-center text-center"
      >
        <h2>З нетерпінням чекаємо вас на нашому святі!</h2>
        <div
          class="flex flex-col items-center justify-end gap-4 w-full relative rounded-lg overflow-hidden min-h-54 text-white bg-ink pb-6.25"
        >
          <Image
            src={finalImg}
            alt="З нетерпінням чекаємо вас на нашому святі"
            class="w-full h-full object-cover absolute top-0 left-0 z-1"
          />
          <div
            id="countdown"
            class="font-h2 number-fix text-[2.25rem]! tracking-[0.19em] relative z-2"
            aria-live="polite"
          >
            <span id="countdown-days">00</span> | <span id="countdown-hours"
              >00</span
            > | <span id="countdown-mins">00</span> | <span id="countdown-secs"
              >00</span
            >
          </div>
          <div
            class="flex flex-row items-center justify-between w-full max-w-81.5 relative z-2"
          >
            <span>Днів</span><span>Год</span><span>Хв</span><span>Сек</span>
          </div>
        </div>
        <p class="text-[#C2C0BE] text-[0.75rem]">
          Design: <a
            href="https://www.instagram.com/poznyakk/"
            target="_blank"
            class="border-b border-transparent transition-all hover:text-black hover:border-inherit"
            >poznyak</a
          > | Development: <a
            href="https://vasukov.com/"
            target="_blank"
            class="border-b border-transparent transition-all hover:text-black hover:border-inherit"
            >Nikita Vasukov</a
          >
        </p>
      </Section>
      <script is:inline src="/scripts/preloader.js"></script>
      <script is:inline src="/scripts/rsvp-form.js"></script>
      <script is:inline src="/scripts/countdown.js"></script>
    </main>
  </body>
</html>
